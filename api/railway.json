{
  "$schema": "https://schema.railway.app/railway-json.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "mvn clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -Xmx300m -Xss512k -XX:+UseSerialGC -Dserver.port=$PORT -jar target/*.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}